{
  "name": "medivault-hms",
  "version": "1.0.0",
  "private": true,
  "description": "MediVault HMS — Premium Hospital Data Management System (Cream × Gold × Sky-Blue)",
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n \"API,WEB\" -c \"yellow,cyan\" \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace apps/server",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "start": "npm run start --workspace apps/server",
    "seed": "npm run seed --workspace apps/server",
    "test": "npm run test --workspace apps/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
