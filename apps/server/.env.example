# ============================================================
#  MediVault HMS — Server Environment
#  Copy to `.env` and adjust. Defaults run instantly (SQLite).
# ============================================================

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=8h

# Database client: "sqlite" (zero-config dev) or "mysql" (production)
DB_CLIENT=sqlite

# SQLite (used when DB_CLIENT=sqlite)
SQLITE_FILE=./data/medivault.sqlite

# MySQL (used when DB_CLIENT=mysql) — matches docker-compose.yml
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=medivault
MYSQL_PASSWORD=medivault_pass
MYSQL_DATABASE=medivault_hms
DB_POOL_MIN=5
DB_POOL_MAX=20

# Default admin seeded on first run
ADMIN_EMAIL=admin@medivault.io
ADMIN_PASSWORD=medivault
